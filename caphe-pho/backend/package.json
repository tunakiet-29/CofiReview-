{
  "name": "caphe-pho-backend",
  "version": "3.0.0",
  "description": "Backend API — JWT + Socket.IO + PostgreSQL + Redis + Swagger",
  "main": "server.js",
  "engines": { "node": ">=20" },
  "scripts": {
    "start":      "node server.js",
    "dev":        "nodemon server.js",
    "migrate":    "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed":       "node data/seed.local.js",
    "seed:postgres": "knex seed:run",
    "test":       "jest --runInBand --forceExit"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "ioredis":            "^5.3.2",
    "jsonwebtoken":       "^9.0.2",
    "knex":               "^3.1.0",
    "pg":                 "^8.11.3",
    "socket.io":          "^4.7.4",
    "sql.js":             "^1.11.0",
    "swagger-jsdoc":      "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod":                "^3.22.4"
  },
  "devDependencies": {
    "jest":       "^29.7.0",
    "nodemon":    "^3.0.3",
    "supertest":  "^6.3.4"
  }
}
